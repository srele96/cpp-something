# http://editorconfig.org
root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
tab_width = 2

[*.py]
indent_size = 4

[*.md]
indent_size = 2
tab_width = 2

[*.{c++,cpp,h,hpp}]
indent_size = 2
tab_width = 2

[*.{json,js,ts,html,css,txt}]
indent_size = 2
